{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build: build_runner build",
      "type": "shell",
      "command": "${workspaceFolder}/.fvm/versions/stable/bin/dart",
      "args": ["run", "build_runner", "build"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$dart-build_runner",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Build: build_runner watch",
      "type": "shell",
      "command": "${workspaceFolder}/.fvm/versions/stable/bin/dart",
      "args": ["run", "build_runner", "watch"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": "$dart-build_runner",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
