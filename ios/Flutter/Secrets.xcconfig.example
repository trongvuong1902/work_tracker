// Copy this file to "Secrets.xcconfig" (same directory) and fill in the
// real value. "Secrets.xcconfig" is gitignored — never commit real API keys.
//
// See docs/leave_reminder_setup.md for which Google Cloud APIs this key
// needs enabled.
GOOGLE_MAPS_API_KEY = YOUR_GOOGLE_MAPS_API_KEY_HERE

// Used by the `dev` scheme/flavor's *-dev.xcconfig files instead of the key
// above, since the dev flavor's bundle identifier differs from prod and an
// iOS-application-restricted key won't authorize it. Fill in a real,
// separately-restricted dev key — falls back to the prod key above if left
// as-is.
GOOGLE_MAPS_API_KEY_DEV = YOUR_DEV_GOOGLE_MAPS_API_KEY_HERE
