default_platform(:ios)

platform :ios do
  desc "Build the release IPA (via repo build script) and upload it to TestFlight"
  lane :beta do
    repo_root = File.expand_path("../..", __dir__)

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: File.expand_path(ENV.fetch("ASC_KEY_FILEPATH"), __dir__)
    )

    latest_build = latest_testflight_build_number(api_key: api_key, initial_build_number: 0)
    ENV["BUILD_NUMBER"] = (latest_build + 1).to_s

    sh("#{repo_root}/scripts/build_release_ipa.sh")

    ipa_path = Dir.glob("#{repo_root}/build/ios/ipa/*.ipa").max_by { |f| File.mtime(f) }
    UI.user_error!("No .ipa found in build/ios/ipa after build_release_ipa.sh") unless ipa_path

    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build the release IPA and submit it to the App Store for review (production)"
  lane :release do
    repo_root = File.expand_path("../..", __dir__)

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: File.expand_path(ENV.fetch("ASC_KEY_FILEPATH"), __dir__)
    )

    # Same monotonic counter as `beta` — TestFlight and the App Store share one
    # CFBundleVersion sequence (see docs/versioning.md).
    latest_build = latest_testflight_build_number(api_key: api_key, initial_build_number: 0)
    ENV["BUILD_NUMBER"] = (latest_build + 1).to_s

    # DART_DEFINES_FILE is inherited from the caller (ship_production.sh sets it
    # to dart_defines.prod.json — AI key omitted). See docs/release_flow.md.
    sh("#{repo_root}/scripts/build_release_ipa.sh")

    ipa_path = Dir.glob("#{repo_root}/build/ios/ipa/*.ipa").max_by { |f| File.mtime(f) }
    UI.user_error!("No .ipa found in build/ios/ipa after build_release_ipa.sh") unless ipa_path

    # Upload the binary, then submit for review. Metadata/screenshots are managed
    # in App Store Connect directly (mirrors how the Android lanes skip metadata);
    # automatic_release is false so a human taps "Release" after approval.
    upload_to_app_store(
      api_key: api_key,
      ipa: ipa_path,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      precheck_include_in_app_purchases: false,
      skip_metadata: true,
      skip_screenshots: true,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false
      }
    )
  end

  desc "Build the release IPA, upload to TestFlight, and distribute it to the External Testers group"
  lane :beta_external do
    repo_root = File.expand_path("../..", __dir__)

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: File.expand_path(ENV.fetch("ASC_KEY_FILEPATH"), __dir__)
    )

    latest_build = latest_testflight_build_number(api_key: api_key, initial_build_number: 0)
    ENV["BUILD_NUMBER"] = (latest_build + 1).to_s

    sh("#{repo_root}/scripts/build_release_ipa.sh")

    ipa_path = Dir.glob("#{repo_root}/build/ios/ipa/*.ipa").max_by { |f| File.mtime(f) }
    UI.user_error!("No .ipa found in build/ios/ipa after build_release_ipa.sh") unless ipa_path

    begin
      # Unlike `beta`, this deliberately does NOT set skip_waiting_for_build_processing:
      # skipping the wait silently disables distribute_external (see pilot docs), so we
      # wait for Apple to finish processing, then distribute to the external group in the
      # same call. This makes the lane long-running (~10-30 min) by design.
      upload_to_testflight(
        api_key: api_key,
        ipa: ipa_path,
        distribute_external: true,
        groups: [ENV.fetch("TESTFLIGHT_GROUP", "External Testers")],
        notify_external_testers: true,
        demo_account_required: false,
        changelog: ENV.fetch("BETA_CHANGELOG", "Bug fixes and improvements."),
        beta_app_review_info: {
          contact_email: ENV.fetch("BETA_CONTACT_EMAIL"),
          contact_first_name: ENV.fetch("BETA_CONTACT_FIRST_NAME"),
          contact_last_name: ENV.fetch("BETA_CONTACT_LAST_NAME"),
          contact_phone: ENV.fetch("BETA_CONTACT_PHONE"),
          notes: "Personal productivity app; no demo account or login required."
        },
        localized_app_info: {
          "en-US" => {
            feedback_email: ENV.fetch("BETA_FEEDBACK_EMAIL"),
            description: ENV.fetch("BETA_APP_DESCRIPTION")
          }
        }
      )
    rescue => e
      raise e unless e.message.include?("Another build is in review")
      UI.important("A build for this app is already pending Apple's external beta review — the new build was uploaded; rerun `distribute_beta` once that review finishes.")
    end
  end

  desc "Submit an already-uploaded TestFlight build to the App Store for review (no rebuild)"
  lane :submit_review do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: File.expand_path(ENV.fetch("ASC_KEY_FILEPATH"), __dir__)
    )

    # Submit the build that's ALREADY on TestFlight for App Store review, rather
    # than rebuilding — so the external-tester build and the reviewed build are
    # the same binary. Defaults to the latest processed build; override with
    # SUBMIT_BUILD_NUMBER to pin a specific one. External TestFlight beta review
    # and App Store review are independent, so a build can be in both at once.
    build_number = (ENV["SUBMIT_BUILD_NUMBER"] || latest_testflight_build_number(api_key: api_key)).to_s

    upload_to_app_store(
      api_key: api_key,
      build_number: build_number,
      skip_binary_upload: true,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      precheck_include_in_app_purchases: false,
      skip_metadata: true,
      skip_screenshots: true,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false
      }
    )
  end

  desc "Distribute the most recently uploaded build to the External Testers group"
  lane :distribute_beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: File.expand_path(ENV.fetch("ASC_KEY_FILEPATH"), __dir__)
    )

    begin
      upload_to_testflight(
        api_key: api_key,
        app_platform: "ios",
        distribute_only: true,
        distribute_external: true,
        groups: [ENV.fetch("TESTFLIGHT_GROUP", "External Testers")],
        notify_external_testers: true,
        demo_account_required: false,
        changelog: ENV.fetch("BETA_CHANGELOG", "Bug fixes and improvements."),
        beta_app_review_info: {
          contact_email: ENV.fetch("BETA_CONTACT_EMAIL"),
          contact_first_name: ENV.fetch("BETA_CONTACT_FIRST_NAME"),
          contact_last_name: ENV.fetch("BETA_CONTACT_LAST_NAME"),
          contact_phone: ENV.fetch("BETA_CONTACT_PHONE"),
          notes: "Personal productivity app; no demo account or login required."
        },
        localized_app_info: {
          "en-US" => {
            feedback_email: ENV.fetch("BETA_FEEDBACK_EMAIL"),
            description: ENV.fetch("BETA_APP_DESCRIPTION")
          }
        }
      )
    rescue => e
      raise e unless e.message.include?("Another build is in review")
      UI.important("A build for this app is already pending Apple's external beta review — rerun `distribute_beta` once that review finishes.")
    end
  end
end
