# Copy to ios/fastlane/.env and fill in real values. Never commit .env.
# App Store Connect API Key — see docs/fastlane_testflight_setup.md
ASC_KEY_ID=YOUR_KEY_ID
ASC_ISSUER_ID=YOUR_ISSUER_ID
# Path to the downloaded .p8, relative to ios/fastlane or absolute
ASC_KEY_FILEPATH=./AuthKey_YOUR_KEY_ID.p8

# Beta App Review contact info (required by Apple for the first external-tester submission per build)
BETA_CONTACT_FIRST_NAME="Your First Name"
BETA_CONTACT_LAST_NAME="Your Last Name"
BETA_CONTACT_EMAIL=you@example.com
BETA_CONTACT_PHONE=+10000000000
BETA_FEEDBACK_EMAIL=you@example.com
BETA_APP_DESCRIPTION="A short description of what this app does, shown to Apple's beta reviewer."

# External TestFlight tester group name (used by distribute_beta and scripts/add_testflight_testers.sh)
TESTFLIGHT_GROUP="External Testers"
