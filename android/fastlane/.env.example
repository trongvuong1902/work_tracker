# Copy to android/fastlane/.env and fill in real values. Never commit .env.
# Firebase App Distribution — see docs/fastlane_firebase_distribution_setup.md
FIREBASE_APP_ID=1:XXXXXXXXXXXX:android:XXXXXXXXXXXXXXXXXXXX
# Path to the downloaded service-account JSON key, relative to android/fastlane or absolute
FIREBASE_SERVICE_ACCOUNT_FILEPATH=./firebase-service-account.json

# App Distribution testers group alias (created once via
# `firebase appdistribution:group:create`), used by both fastlane lanes.
FIREBASE_GROUP=beta-testers

# Release notes shown to testers for each distributed build
FIREBASE_RELEASE_NOTES="Bug fixes and improvements."

# Google Play Store (Play Developer API) — see docs/play_store_setup.md
# Must match android/app/build.gradle.kts's applicationId exactly.
PLAY_STORE_PACKAGE_NAME=io.fury.workTracker
# Path to the downloaded Play Console service-account JSON key, relative to
# android/fastlane or absolute. Gitignored via /android/fastlane/*.json.
PLAY_STORE_JSON_KEY_FILEPATH=./play-console-service-account.json
# Track the `internal` lane uploads to.
PLAY_STORE_TRACK=internal

# Play App Signing upload keystore. ANDROID_KEYSTORE_FILEPATH MUST be an
# absolute path (dotenv does not expand ~ or shell variables, and Gradle
# needs an unambiguous path). Never commit the .jks itself.
ANDROID_KEYSTORE_FILEPATH=/absolute/path/to/android/fastlane/upload-keystore.jks
ANDROID_KEYSTORE_PASSWORD=changeme
ANDROID_KEY_ALIAS=upload
ANDROID_KEY_PASSWORD=changeme
