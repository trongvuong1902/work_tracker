default_platform(:android)

platform :android do
  desc "Build the release APK (via repo build script) and distribute it via Firebase App Distribution"
  lane :beta do
    distribute_firebase(group: ENV.fetch("FIREBASE_GROUP", "beta-testers"))
  end

  desc "Build the release APK (via repo build script) and distribute it via Firebase App Distribution to the 'internal' testers group"
  lane :internal do
    distribute_firebase(group: "internal")
  end

  desc "Add/update testers from android/fastlane/internal_testers.txt into the Firebase 'internal' testers group"
  lane :add_internal_testers do
    add_testers_from_file(file: "internal_testers.txt", group: "internal")
  end

  desc "Add/update testers from android/fastlane/nexsoft_testers.txt into the Firebase 'Nexsoft' testers group"
  lane :add_nexsoft_testers do
    add_testers_from_file(file: "nexsoft_testers.txt", group: "Nexsoft")
  end

  # Builds the release APK via the repo build script and uploads it to Firebase
  # App Distribution, notifying the given tester [group]. Shared by `beta` and
  # `internal` so their build/upload behaviour never diverges — the only
  # difference is which tester group is notified.
  private_lane :distribute_firebase do |options|
    repo_root = File.expand_path("../..", __dir__)

    # versionName comes from pubspec.yaml — a deliberate human decision (see
    # docs/versioning.md). CI only ever sets the build NUMBER, drawn from the
    # Firebase counter so successive builds of the same version read as
    # "1.1.0 (11)", "1.1.0 (12)", … rather than bumping the semantic version.
    ENV["BUILD_NUMBER"] = next_android_version_code.to_s

    sh("#{repo_root}/scripts/build_release_apk.sh")

    apk_path = Dir.glob("#{repo_root}/build/app/outputs/flutter-apk/*-release.apk").max_by { |f| File.mtime(f) }
    UI.user_error!("No release .apk found in build/app/outputs/flutter-apk after build_release_apk.sh") unless apk_path

    firebase_app_distribution(
      app: ENV.fetch("FIREBASE_APP_ID"),
      service_credentials_file: File.expand_path(ENV.fetch("FIREBASE_SERVICE_ACCOUNT_FILEPATH"), __dir__),
      apk_path: apk_path,
      groups: options[:group],
      release_notes: ENV.fetch("FIREBASE_RELEASE_NOTES", "Bug fixes and improvements.")
    )
  end

  # Next Android versionCode, drawn from the latest Firebase App Distribution
  # release + 1 so every build is a strictly-higher, distinct release (Firebase
  # keys releases by versionName+versionCode; a repeated code just updates the
  # existing one). Both `beta` and `internal` use this so their counters never
  # diverge.
  private_lane :next_android_version_code do
    firebase_latest = firebase_app_distribution_get_latest_release(
      app: ENV.fetch("FIREBASE_APP_ID"),
      service_credentials_file: File.expand_path(ENV.fetch("FIREBASE_SERVICE_ACCOUNT_FILEPATH"), __dir__)
    )
    # The release object exposes the build number as `buildVersion` (the
    # version name is `displayVersion`).
    firebase_code = firebase_latest ? (firebase_latest["buildVersion"] || firebase_latest[:buildVersion]).to_i : 0
    firebase_code + 1
  end

  private_lane :add_testers_from_file do |options|
    # firebase_app_distribution_add_testers takes the Firebase *project number*,
    # not the app id — parse it out of FIREBASE_APP_ID (format "1:PROJECT_NUMBER:android:HASH")
    # rather than requiring a separate env var.
    project_number = ENV.fetch("FIREBASE_APP_ID").split(":")[1]
    UI.user_error!("Could not parse Firebase project number from FIREBASE_APP_ID (expected format '1:PROJECT_NUMBER:android:HASH')") unless project_number

    firebase_app_distribution_add_testers(
      project_number: project_number,
      service_credentials_file: File.expand_path(ENV.fetch("FIREBASE_SERVICE_ACCOUNT_FILEPATH"), __dir__),
      file: File.expand_path(options[:file], __dir__),
      group_alias: options[:group]
    )
  end
end
